{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Reloadux Design System — Semantic Tokens",
    "version": "1.1.0",
    "description": "Meaningful aliases that reference primitive tokens by purpose (Home + Work Page)"
  },

  "color": {
    "text": {
      "primary":    { "value": "{color.base.white}",    "type": "color", "description": "Primary text on dark surfaces" },
      "secondary":  { "value": "{color.grey.400}",      "type": "color", "description": "Muted secondary text" },
      "tertiary":   { "value": "{color.grey.200}",      "type": "color", "description": "Subtle tertiary text (e.g. CTA sub-line)" },
      "inverse":    { "value": "{color.base.night}",    "type": "color", "description": "Text on light backgrounds" },
      "on-dark":    { "value": "{color.base.white}",    "type": "color", "description": "Text on dark sections" },
      "muted":      { "value": "rgba(255, 255, 255, 0.8)", "type": "color", "description": "Hero subtitle text" },
      "tag":        { "value": "{color.grey.400}",      "type": "color", "description": "Uppercase tag/label text" },
      "grey":       { "value": "{color.grey-nav.text}",  "type": "color", "description": "General grey text (body paragraphs on light bg)" },
      "nav":        { "value": "{color.grey-nav.default}", "type": "color", "description": "Navigation link text" },
      "slate":      { "value": "{color.grey.50}",         "type": "color", "description": "Slate grey text (Work Page descriptions)" },
      "link":       { "value": "{color.base.white}",    "type": "color", "description": "Link text on dark surfaces" },
      "success":    { "value": "{color.green.500}",     "type": "color" },
      "error":      { "value": "{color.red.600}",       "type": "color" },
      "warning":    { "value": "{color.brand-secondary.sunset.700}", "type": "color" },
      "info":       { "value": "{color.blue.500}",      "type": "color" }
    },

    "bg": {
      "page":       { "value": "{color.base.white}",    "type": "color", "description": "Default page background" },
      "surface":    { "value": "{color.neutral.100}",   "type": "color", "description": "Subtle off-white surface" },
      "elevated":   { "value": "{color.base.white}",    "type": "color", "description": "Cards, elevated elements" },
      "dark":       { "value": "{color.base.night}",    "type": "color", "description": "Dark section background" },
      "darker":     { "value": "{color.base.black}",    "type": "color", "description": "Deepest background" },
      "cta":        { "value": "{color.base.night}",    "type": "color", "description": "CTA section base surface" },
      "card-dark":  { "value": "{color.grey.05}",       "type": "color", "description": "Dark card surfaces (Work Page case studies)" },
      "alt-dark":   { "value": "{color.base.dark-bg}",  "type": "color", "description": "Alternate dark bg — slightly lighter than night" },
      "light-surface": { "value": "{color.base.light}", "type": "color", "description": "Near-white surface for light sections" },
      "overlay":    { "value": "rgba(0, 0, 0, 0.6)",    "type": "color", "description": "Modal / overlay backdrop" },
      "success":    { "value": "{color.green.100}",     "type": "color" },
      "error":      { "value": "{color.red.50}",        "type": "color" },
      "info":       { "value": "{color.purple.50}",     "type": "color" }
    },

    "border": {
      "default":  { "value": "{color.base.smoke}",     "type": "color", "description": "Default border / divider" },
      "subtle":   { "value": "{color.neutral.200}",    "type": "color", "description": "Subtle border / separator" },
      "strong":   { "value": "{color.grey.400}",       "type": "color", "description": "Stronger emphasis border" },
      "focus":    { "value": "{color.base.white}",     "type": "color", "description": "Focus ring on dark bg" },
      "outline":  { "value": "{color.brand-secondary.outline.default}", "type": "color", "description": "Light outline on card edges (Work Page)" }
    },

    "icon": {
      "default":    { "value": "{color.base.white}",    "type": "color" },
      "on-dark":    { "value": "{color.base.white}",    "type": "color" },
      "muted":      { "value": "{color.grey.400}",      "type": "color" },
      "inverse":    { "value": "{color.base.night}",    "type": "color" }
    },

    "interactive": {
      "primary":    { "value": "{color.base.white}",    "type": "color", "description": "Primary CTA fill" },
      "primary-fg": { "value": "{color.base.black}",    "type": "color", "description": "Text on primary CTA" },
      "secondary":  { "value": "transparent",           "type": "color", "description": "Outline button fill" },
      "hover":      { "value": "{color.base.smoke}",    "type": "color", "description": "Primary CTA hover" },
      "accent":     { "value": "{color.purple.500}",    "type": "color", "description": "Purple accent elements" }
    }
  },

  "typography": {
    "display": {
      "font-family":    { "value": "{typography.font-family.primary}" },
      "font-size":      { "value": "{typography.font-size.80}" },
      "font-weight":    { "value": "{typography.font-weight.extrabold}" },
      "line-height":    { "value": "{typography.line-height.90}" },
      "letter-spacing": { "value": "{typography.letter-spacing.none}" },
      "description":    "CTA display heading (80px ExtraBold)"
    },
    "hero": {
      "font-family":    { "value": "{typography.font-family.primary}" },
      "font-size":      { "value": "{typography.font-size.70}" },
      "font-weight":    { "value": "{typography.font-weight.medium}" },
      "line-height":    { "value": "{typography.line-height.88}" },
      "letter-spacing": { "value": "{typography.letter-spacing.none}" },
      "description":    "Hero title (70px Medium)"
    },
    "heading-xl": {
      "font-family":    { "value": "{typography.font-family.primary}" },
      "font-size":      { "value": "{typography.font-size.50}" },
      "font-weight":    { "value": "{typography.font-weight.regular}" },
      "line-height":    { "value": "{typography.line-height.68}" },
      "letter-spacing": { "value": "{typography.letter-spacing.none}" },
      "description":    "Heading XL (50px Regular) — Work Page hero subtitle"
    },
    "heading-lg": {
      "font-family":    { "value": "{typography.font-family.primary}" },
      "font-size":      { "value": "{typography.font-size.48}" },
      "font-weight":    { "value": "{typography.font-weight.medium}" },
      "line-height":    { "value": "{typography.line-height.100}" },
      "letter-spacing": { "value": "{typography.letter-spacing.none}" },
      "description":    "Section heading large (48px Medium)"
    },
    "heading-md": {
      "font-family":    { "value": "{typography.font-family.serif}" },
      "font-size":      { "value": "{typography.font-size.40}" },
      "font-weight":    { "value": "{typography.font-weight.regular}" },
      "line-height":    { "value": "{typography.line-height.53}" },
      "letter-spacing": { "value": "{typography.letter-spacing.none}" },
      "description":    "Heading H3 (40px Libre Baskerville)"
    },
    "heading-sm": {
      "font-family":    { "value": "{typography.font-family.primary}" },
      "font-size":      { "value": "{typography.font-size.30}" },
      "font-weight":    { "value": "{typography.font-weight.medium}" },
      "line-height":    { "value": "{typography.line-height.48}" },
      "letter-spacing": { "value": "{typography.letter-spacing.none}" },
      "description":    "Card title / subheading (30px Medium)"
    },
    "paragraph-xl": {
      "font-family":    { "value": "{typography.font-family.primary}" },
      "font-size":      { "value": "{typography.font-size.28}" },
      "font-weight":    { "value": "{typography.font-weight.regular}" },
      "line-height":    { "value": "{typography.line-height.48}" },
      "description":    "Paragraph large (28px Regular)"
    },
    "paragraph-lg": {
      "font-family":    { "value": "{typography.font-family.primary}" },
      "font-size":      { "value": "{typography.font-size.22}" },
      "font-weight":    { "value": "{typography.font-weight.regular}" },
      "line-height":    { "value": "{typography.line-height.40}" },
      "description":    "Paragraph medium (22px Regular)"
    },
    "paragraph-md": {
      "font-family":    { "value": "{typography.font-family.primary}" },
      "font-size":      { "value": "{typography.font-size.20}" },
      "font-weight":    { "value": "{typography.font-weight.regular}" },
      "line-height":    { "value": "{typography.line-height.28}" },
      "description":    "Paragraph standard (20px Regular)"
    },
    "body": {
      "font-family":    { "value": "{typography.font-family.primary}" },
      "font-size":      { "value": "{typography.font-size.18}" },
      "font-weight":    { "value": "{typography.font-weight.regular}" },
      "line-height":    { "value": "{typography.line-height.100}" },
      "description":    "Body text (18px Regular)"
    },
    "body-semibold": {
      "font-family":    { "value": "{typography.font-family.primary}" },
      "font-size":      { "value": "{typography.font-size.18}" },
      "font-weight":    { "value": "{typography.font-weight.semibold}" },
      "line-height":    { "value": "{typography.line-height.100}" },
      "description":    "Body semibold (18px SemiBold) — card labels, emphasis text"
    },
    "body-sm-semibold": {
      "font-family":    { "value": "{typography.font-family.primary}" },
      "font-size":      { "value": "{typography.font-size.16}" },
      "font-weight":    { "value": "{typography.font-weight.semibold}" },
      "line-height":    { "value": "{typography.line-height.26}" },
      "description":    "Body small semibold (16px SemiBold) — tags, badges"
    },
    "body-sm": {
      "font-family":    { "value": "{typography.font-family.primary}" },
      "font-size":      { "value": "{typography.font-size.16}" },
      "font-weight":    { "value": "{typography.font-weight.regular}" },
      "line-height":    { "value": "{typography.line-height.26}" },
      "description":    "Body small (16px Regular, 26px line-height)"
    },
    "tag": {
      "font-family":    { "value": "{typography.font-family.serif}" },
      "font-size":      { "value": "{typography.font-size.18}" },
      "font-weight":    { "value": "{typography.font-weight.regular}" },
      "line-height":    { "value": "{typography.line-height.60}" },
      "letter-spacing": { "value": "{typography.letter-spacing.wider}" },
      "description":    "Uppercase tag / section label (Libre Baskerville 18px)"
    },
    "tag-sm": {
      "font-family":    { "value": "{typography.font-family.serif}" },
      "font-size":      { "value": "{typography.font-size.16}" },
      "font-weight":    { "value": "{typography.font-weight.regular}" },
      "line-height":    { "value": "{typography.line-height.60}" },
      "letter-spacing": { "value": "{typography.letter-spacing.tight}" },
      "description":    "Small tag (Libre Baskerville 16px uppercase)"
    },
    "label": {
      "font-family":    { "value": "{typography.font-family.primary}" },
      "font-size":      { "value": "{typography.font-size.14}" },
      "font-weight":    { "value": "{typography.font-weight.regular}" },
      "line-height":    { "value": "{typography.line-height.22}" },
      "description":    "Small label / caption (14px Regular)"
    },
    "button-lg": {
      "font-family":    { "value": "{typography.font-family.primary}" },
      "font-size":      { "value": "{typography.font-size.16}" },
      "font-weight":    { "value": "{typography.font-weight.medium}" },
      "line-height":    { "value": "{typography.line-height.100}" },
      "description":    "Button text (16px Medium)"
    },
    "button-xl": {
      "font-family":    { "value": "{typography.font-family.primary}" },
      "font-size":      { "value": "{typography.font-size.20}" },
      "font-weight":    { "value": "{typography.font-weight.medium}" },
      "line-height":    { "value": "{typography.line-height.28}" },
      "description":    "Large button text (20px Medium)"
    },
    "italic-accent": {
      "font-family":    { "value": "{typography.font-family.serif}" },
      "font-weight":    { "value": "{typography.font-weight.regular}" },
      "letter-spacing": { "value": "{typography.letter-spacing.wide}" },
      "description":    "Italic serif accent words (Libre Baskerville Italic)"
    }
  },

  "spacing": {
    "section-block":  { "value": "{spacing.120}",  "description": "Vertical section padding" },
    "section-inline": { "value": "{spacing.80}",   "description": "Horizontal page gutters" },
    "content-gap":    { "value": "{spacing.120}",  "description": "Gap between content blocks" },
    "card-gap":       { "value": "{spacing.40}",   "description": "Gap between cards in a list" },
    "stack-lg":       { "value": "{spacing.60}",   "description": "Large vertical stack spacing" },
    "stack-md":       { "value": "{spacing.32}",   "description": "Medium vertical stack spacing" },
    "stack-sm":       { "value": "{spacing.20}",   "description": "Small vertical stack spacing" },
    "inline-md":      { "value": "{spacing.8}",    "description": "Inline element spacing (icon+text)" }
  },

  "radius": {
    "button":    { "value": "{border-radius.30}",   "description": "Primary button pill" },
    "card":      { "value": "{border-radius.12}",   "description": "Card corners" },
    "tag":       { "value": "{border-radius.8}",    "description": "Tag / badge" },
    "circle":    { "value": "{border-radius.full}",  "description": "Circular elements" }
  },

  "shadow": {
    "cta-glow":   { "value": "{shadow.button-glow}",  "description": "CTA button white glow halo" },
    "card-rest":  { "value": "{shadow.card}",          "description": "Card resting state" },
    "card-hover": { "value": "{shadow.natural}",       "description": "Card hover / elevated" }
  }
}
